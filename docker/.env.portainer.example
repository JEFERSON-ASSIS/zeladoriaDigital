# Imagens (build + push antes do deploy)
ZELADORIA_API_IMAGE=ghcr.io/jeferson-assis/zeladoria-api:homolog
ZELADORIA_WEB_IMAGE=ghcr.io/jeferson-assis/zeladoria-web:homolog

# URLs públicas (homolog)
APP_URL=https://homolog.prefeituranamao.com.br
API_URL=https://api-homolog.prefeituranamao.com.br

# Auth
JWT_SECRET=troque-por-string-longa-e-aleatoria
JWT_EXPIRES_IN=1d

# Postgres (interno na rede Docker — NÃO use localhost aqui)
POSTGRES_DB=zeladoria
POSTGRES_USER=zeladoria
POSTGRES_PASSWORD=troque-senha-forte

# MinIO (opcional — API hoje usa disco em /app/uploads)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=troque-senha-forte
MINIO_BUCKET=zeladoria

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@prefeituranamao.com.br

# WhatsApp (opcional)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_FROM_NUMBER=
